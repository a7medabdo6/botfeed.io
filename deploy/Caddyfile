# TLS + routing on a single DigitalOcean Droplet.
# DNS: botfeed.io, www, api, dashboard → this host.

botfeed.io, www.botfeed.io {
	encode gzip zstd
	reverse_proxy web:3000
}

dashboard.botfeed.io {
	encode gzip zstd
	reverse_proxy admin:3000
}

api.botfeed.io {
	encode gzip zstd
	reverse_proxy api:5000
}
