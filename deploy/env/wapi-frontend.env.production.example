# Botfeed web app — copy to `Wapi-frontend/.env.production` on the server (repo folder name).

NODE_ENV=production
NEXTAUTH_URL=https://botfeed.io
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NEXT_PUBLIC_API_URL = real API for Next server (BFF routes, SSR). NEXT_PUBLIC_API_BASE_URL = browser RTK base (use /api on same origin).
NEXT_PUBLIC_API_URL=https://api.botfeed.io/api
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_STORAGE_URL=https://api.botfeed.io
NEXT_PUBLIC_SOCKET_URL=https://api.botfeed.io
