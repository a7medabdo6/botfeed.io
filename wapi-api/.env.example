# ==================================
# STRIPE CONFIGURATION
# ==================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ==================================
# RAZORPAY CONFIGURATION
# ==================================
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ==================================
# WEBHOOK URLS (For Testing)
# ==================================
# Stripe Webhook URL: https://yourdomain.com/api/webhook/stripe
# Razorpay Webhook URL: https://yourdomain.com/api/webhook/razorpay

# ==================================
# OTHER EXISTING CONFIGURATIONS
# ==================================
# Add your other existing environment variables here
PAYPAL_MODE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

JWT_SECRET=your_jwt_secret_here
MONGODB_URI=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL= # Use this if you have a Redis connection string instead of individual params
# Comma-separated browser origins allowed to call this API (scheme + host + port, no path).
# Production example (frontend on botfeed.io):
# ALLOWED_ORIGINS=https://botfeed.io,https://www.botfeed.io
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# Public URL of the Next.js app (OAuth redirect after Google). Production: https://botfeed.io
FRONTEND_URL=http://localhost:3000

# Google OAuth (Calendar / Sheets) — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client (Web). Authorized JavaScript origins: https://botfeed.io (and www if used).
# Authorized redirect URIs: must be THIS API callback URL exactly, e.g.:
#   https://YOUR_API_HOST/api/google/callback
# (Not the Next.js URL — Google posts the code to your backend.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback
ADMIN_NAME=admin_name
ADMIN_EMAIL=admin_email
ADMIN_PASSWORD=admin_password
WHATSAPP_VERIFY_TOKEN=
APP_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=
MAIL_FROM_EMAIL=
SUPPORT_EMAIL=
MAINTENANCE_MODE=
SERVER_ADDR=
APP_URL=
APP_ID=VVlHTldWMk4wSQ==

# OpenRouter (optional; improves attribution on openrouter.ai rankings)
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=Botfeed